@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Login TESCo</title>
    <style>
        body {
            background-color: #0f4d2c;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            font-family: Arial;
        }

        .card {
            background: white;
            padding: 40px;
            border-radius: 8px;
            width: 350px;
            text-align: center;
        }

        h2 {
            color: #0f4d2c;
        }

        input {
            width: 100%;
            padding: 10px;
            margin: 10px 0;
        }

        button {
            width: 100%;
            padding: 10px;
            background-color: #0f4d2c;
            color: white;
            border: none;
        }

        button:hover {
            background-color: #0c3d23;
        }

        a {
            display: block;
            margin-top: 10px;
        }
    </style>
</head>
<body>

<div class="card">
    <h2>TESCo - Centro Académico</h2>

    <form method="post" asp-action="Login" asp-controller="Account" autocomplete="off">
        @Html.AntiForgeryToken()

        <input name="email" placeholder="Correo institucional" required />
        <input name="password" type="password" placeholder="Contraseña" required />
        <button type="submit">Iniciar Sesión</button>

        <a asp-action="Register" asp-controller="Account">Registrarse</a>
    </form>

    @if (ViewBag.Error != null)
    {
        <p style="color:red">@ViewBag.Error</p>
    }
</div>

</body>
</html>