<h2>Calendario de Citas</h2>

<label>Profesional</label>

<select id="profesional" class="form-control">

<option value="">Todos</option>

@foreach(var p in ViewBag.Profesionales)
{
<option value="@p.Nombre @p.Apellidos">
@p.Nombre @p.Apellidos
</option>
}

</select>

<br>

<div id="calendar"></div>

<link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.js"></script>

<script>

var calendar;

document.addEventListener('DOMContentLoaded', function() {

var calendarEl = document.getElementById('calendar');

calendar = new FullCalendar.Calendar(calendarEl, {

initialView: 'timeGridWeek',

locale: 'es',

events: function(fetchInfo, successCallback) {

let profesional = document.getElementById("profesional").value;

fetch('/Citas/Eventos?profesional=' + profesional)
.then(res => res.json())
.then(data => successCallback(data));

},

eventClick: function(info) {

alert(
"Cita con: " + info.event.title +
"\nLugar: " + info.event.extendedProps.lugar
);

}

});

calendar.render();

});

document.getElementById("profesional").addEventListener("change", function(){

calendar.refetchEvents();

});

</script>