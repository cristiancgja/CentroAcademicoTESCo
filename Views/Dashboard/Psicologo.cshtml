@model List<CentroAcademicoSQLite.Models.Cita>

<h2 class="text-success">Bienvenido(a) al Sistema Institucional TESCo</h2>

<div class="row mt-4">

<div class="col-md-4">
<div class="card shadow border-warning">
<div class="card-body text-center">

<h5>Citas Pendientes</h5>
<h2>@Model.Count(c => c.Asistio == null)</h2>

</div>
</div>
</div>

<div class="col-md-4">
<div class="card shadow border-primary">
<div class="card-body text-center">

<h5>Sesiones Hoy</h5>
<h2>@Model.Count(c => c.FechaHora.Date == DateTime.Today)</h2>

</div>
</div>
</div>

<div class="col-md-4">
<div class="card shadow border-success">
<div class="card-body text-center">

<h5>Intervenciones</h5>
<h2>@Model.Count(c => c.Asistio == true)</h2>

</div>
</div>
</div>

</div>


<div class="row mt-4">

<div class="col-md-7">

<div class="card shadow">

<div class="card-body">

<h5>Citas de Hoy</h5>

<table class="table">

<thead>

<tr>
<th>Hora</th>
<th>Paciente</th>
<th>Lugar</th>
</tr>

</thead>

<tbody>

@foreach(var c in Model.Where(c => c.FechaHora.Date == DateTime.Today)
                      .OrderBy(c => c.FechaHora))
{

<tr>

<td>@c.FechaHora.ToShortTimeString()</td>

<td>@c.Usuario?.Nombre @c.Usuario?.Apellidos</td>

<td>@c.Lugar</td>

</tr>

}

</tbody>

</table>

<a class="btn btn-success"
asp-controller="Citas"
asp-action="Create">

+ Nueva Cita

</a>

</div>

</div>

</div>


<div class="col-md-5">

<div class="card shadow">

<div class="card-body">

<h5>Historial de Pacientes</h5>

<input id="buscarPaciente"
class="form-control"
placeholder="Buscar paciente..." />

<br>

<ul class="list-group">

@foreach(var p in Model
    .Where(c=>c.Usuario != null)
    .GroupBy(c=>c.UsuarioId)
    .Select(g=>g.First()))
{

<li class="list-group-item">

<strong>@p.Usuario?.Nombre @p.Usuario?.Apellidos</strong>

<br>

<small>@p.Lugar</small>

<br>

<a asp-controller="UserManagement"
asp-action="Expediente"
asp-route-id="@p.UsuarioId"
class="btn btn-sm btn-outline-primary mt-1">

Ver Expediente

</a>

</li>

}

</ul>

</div>

</div>

</div>

</div>