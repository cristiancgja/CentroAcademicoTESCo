@model List<CentroAcademicoSQLite.Models.Cita>

<h2 class="text-success">Bienvenido al Sistema Institucional TESCo</h2>

<div class="row mt-4">

<div class="col-md-6">
<div class="card shadow">
<div class="card-body">

<h5>Próxima Cita</h5>

@if(Model != null && Model.Any())
{
var cita = Model.OrderBy(c => c.FechaHora).First();

<p><strong>Fecha:</strong> @cita.FechaHora.ToString("dd/MM/yyyy HH:mm")</p>
<p><strong>Lugar:</strong> @cita.Lugar</p>
<p><strong>Profesional:</strong> @cita.Profesional</p>
<p><strong>Estatus:</strong> @cita.EstatusProceso</p>
}

else
{
<p>No tienes citas programadas.</p>
}

</div>
</div>
</div>

<div class="col-md-6">
<div class="card shadow">
<div class="card-body">

<h5>Total de Citas</h5>
<h2>@(Model?.Count ?? 0)</h2>

</div>
</div>
</div>

</div>

<hr>

<h3>Historial de Citas</h3>

<table class="table table-striped">

<thead>

<tr>
<th>Fecha</th>
<th>Lugar</th>
<th>Profesional</th>
<th>Estatus</th>
<th>Comentarios</th>
<th>Archivo</th>
</tr>

</thead>

<tbody>

@if(Model != null)
{
foreach(var cita in Model)
{

<tr>

<td>@cita.FechaHora.ToString("dd/MM/yyyy HH:mm")</td>

<td>@cita.Lugar</td>

<td>@cita.Profesional</td>

<td>@cita.EstatusProceso</td>

<td>@cita.Comentarios</td>

<td>

@if(!string.IsNullOrEmpty(cita.Archivo))
{
<a href="/archivos/@cita.Archivo" target="_blank" class="btn btn-sm btn-primary">
Ver archivo
</a>
}

</td>

</tr>

}
}

</tbody>

</table>