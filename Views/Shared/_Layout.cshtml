@using Microsoft.AspNetCore.Identity
@inject SignInManager<CentroAcademicoSQLite.Models.ApplicationUser> SignInManager
@inject UserManager<CentroAcademicoSQLite.Models.ApplicationUser> UserManager

<!DOCTYPE html>
<html>
<head>

<meta charset="utf-8" />

<title>TESCo - Centro Académico</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<link rel="stylesheet"
href="https://code.jquery.com/ui/1.13.2/themes/base/jquery-ui.css">

<style>

.navbar-custom{
background-color:#0f4d2c;
}

.btn-tesco{
background-color:#0f4d2c;
color:white;
}

.btn-tesco:hover{
background-color:#0c3d23;
color:white;
}

</style>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
</head>

<body>

@if(SignInManager.IsSignedIn(User))
{

<nav class="navbar navbar-expand-lg navbar-dark navbar-custom">

<div class="container-fluid">

@if (User.IsInRole("Admin"))
{
<a class="navbar-brand" asp-controller="Dashboard" asp-action="Admin">
TESCo - Centro Académico
</a>
}
else if (User.IsInRole("Alumno"))
{
<a class="navbar-brand" asp-controller="Dashboard" asp-action="Alumno">
TESCo - Centro Académico
</a>
}
else if (User.IsInRole("Profesor"))
{
<a class="navbar-brand" asp-controller="Dashboard" asp-action="Profesor">
TESCo - Centro Académico
</a>
}
else if (User.IsInRole("Psicologo"))
{
<a class="navbar-brand" asp-controller="Dashboard" asp-action="Psicologo">
TESCo - Centro Académico
</a>
}
else if (User.IsInRole("Asesor"))
{
<a class="navbar-brand" asp-controller="Dashboard" asp-action="Asesor">
TESCo - Centro Académico
</a>
}

<div class="collapse navbar-collapse">

<ul class="navbar-nav me-auto">

@if (User.IsInRole("Admin"))
{

<li class="nav-item dropdown">

<a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
Registrar
</a>

<ul class="dropdown-menu">

<li>
<a class="dropdown-item"
asp-controller="UserManagement"
asp-action="Create">
Alumno
</a>
</li>

<li>
<a class="dropdown-item"
asp-controller="Profesores"
asp-action="Create">
Profesor
</a>
</li>

<li>
<a class="dropdown-item"
asp-controller="Psicologos"
asp-action="Create">
Psicólogo
</a>
</li>

</ul>

</li>


<li class="nav-item dropdown">

<a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
Ver
</a>

<ul class="dropdown-menu">

<li>
<a class="dropdown-item"
asp-controller="UserManagement"
asp-action="Index">
Alumnos
</a>
</li>

<li>
<a class="dropdown-item"
asp-controller="Profesores"
asp-action="Index">
Profesores
</a>
</li>

<li>
<a class="dropdown-item"
asp-controller="Psicologos"
asp-action="Index">
Psicólogos
</a>
</li>

</ul>

</li>

}

@if (
User.IsInRole("Admin") ||
User.IsInRole("Profesor") ||
User.IsInRole("Psicologo") ||
User.IsInRole("Asesor")
)

{

<li class="nav-item dropdown">

<a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
Citas
</a>

<ul class="dropdown-menu">

<li>
<a class="dropdown-item"
asp-controller="Citas"
asp-action="Create">
Agendar Cita
</a>
</li>

<li>
<a class="dropdown-item"
asp-controller="Citas"
asp-action="Calendario">
Calendario de Citas
</a>
</li>

</ul>

</li>

}

@if (
User.IsInRole("Profesor") ||
User.IsInRole("Psicologo") ||
User.IsInRole("Asesor")
)

{

<li class="nav-item">

<a class="nav-link"
asp-controller="UserManagement"
asp-action="Index">

Ver Alumnos

</a>

</li>

<li class="nav-item">

<a class="nav-link"
asp-controller="UserManagement"
asp-action="Canalizados">

Alumnos Canalizados

</a>

</li>

}

</ul>

<span class="navbar-text text-white me-3">
@User.Identity?.Name
</span>

<a class="btn btn-light"
asp-controller="Account"
asp-action="Logout">

Cerrar Sesión

</a>

</div>

</div>

</nav>

}

<div class="container mt-4">
@RenderBody()
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script src="https://code.jquery.com/ui/1.13.2/jquery-ui.min.js"></script>

</body>

</html>